# Copy to `.env` in the project root and fill in. Re-run `npm run build` (or `npm run dev`) after changes.
#
# Vite only exposes variables prefixed with VITE_. They are inlined into the extension bundle at build time —
# anyone with `dist/` can read them. Use for local/dev defaults or team templates; not for secrets you must hide.
#
# Host may be `your-org.atlassian.net` or full URL `https://your-org.atlassian.net/` (protocol stripped).
VITE_JIRA_HOST=
VITE_JIRA_EMAIL=
VITE_JIRA_API_TOKEN=
